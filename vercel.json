{
  "rewrites": [
    { "source": "/(.*).html", "destination": "/public/$1.html" },
    { "source": "/api/sumsub/image", "destination": "/api/sumsub/applicant" },
    { "source": "/api/sumsub/metadata", "destination": "/api/sumsub/applicant" },
    { "source": "/api/orderbook/archive-upsert", "destination": "/api/orderbook/archive" },
    { "source": "/api/eft/pending-transactions", "destination": "/api/send-eft-email?action=pending-transactions" },
    { "source": "/api/eft/ozow-transactions", "destination": "/api/send-eft-email?action=ozow-transactions" },
    { "source": "/api/return-alerts/notify", "destination": "/api/mint-mornings?action=return-alerts" },
    { "source": "/api/dividends/extract", "destination": "/api/team?fwd=dividends-extract" },
    { "source": "/api/dividends/runs", "destination": "/api/team?fwd=dividends-runs" },
    { "source": "/api/dividends/payouts", "destination": "/api/team?fwd=dividends-payouts" },
    { "source": "/api/dividends/email", "destination": "/api/team?fwd=dividends-email" },
    { "source": "/api/alliance-news", "destination": "/api/team?fwd=alliance-news" },
    { "source": "/api/tasks/:id", "destination": "/api/team?fwd=tasks&taskId=:id" },
    { "source": "/api/tasks", "destination": "/api/team?fwd=tasks" },
    { "source": "/api/standup-log", "destination": "/api/team?fwd=standup-log" },
    { "source": "/api/standup-log/snapshot", "destination": "/api/team?fwd=standup-log&action=snapshot" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    {
      "path": "/api/orderbook/cron-daily",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/standup-log/snapshot",
      "schedule": "0 22 * * *"
    }
  ]
}
